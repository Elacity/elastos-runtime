# Rust
**/target/
**/*.rs.bk
# Main Cargo.lock committed for reproducible builds; negate the ignore
!elastos/Cargo.lock

# Node.js
node_modules/
dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# ElastOS
elastos/storage/
*.wasm
*.gba

# Vendored GBA runtime + tracked open-source ROM
!capsules/gba-emulator/mgba.js
!capsules/gba-emulator/mgba.wasm

# Allow tracked ROM templates (uCity Advance is open-source)
!capsules/gba-ucity/ucity.gba

# Logs
*.log

# Large binary files (MicroVM rootfs, VM kernels)
*.ext4
*.ext4.downloading
**/kernel/vmlinux

# Build artifacts (release tarballs, platform binaries)
artifacts/
artifacts-aarch64/

# Secrets and credentials
.env
*.pem
*.key
*.hex
*.secret
credentials.json

# Cache
.elastos/

# Claude Code (user-specific settings)
.claude/

# External dependencies
puter-upstream/

# Release publisher state (local)
/.last-release-cid
/.last-release-head-cid
/last-install-script-cid
/last-ipns-name
/last-public-install-url
/last-release-cid
/last-release-head-cid
__pycache__/

